ean, drop_first=True)\ntrain_encoded, test_encoded = train_encoded.align(test_encoded, join='left', axis=1, fill_value=0)\n\nif 'exam_score' in test_encoded.columns:\n    test_encoded = test_encoded.drop(columns=['exam_score'])\n\nX = train_encoded.drop(columns=['exam_score'])\ny = train_encoded['exam_score']\nX_test = test_encoded\n\nestimators = [\n    ('xgb', XGBRegressor(n_estimators=2000, learning_rate=0.015, max_depth=7, subsample=0.8, colsample_bytree=0.8, random_state=42, n_jobs=-1)),\n    ('lgb', LGBMRegressor(n_estimators=2000, learning_rate=0.015, max_depth=7, subsample=0.8, colsample_bytree=0.8, random_state=42, n_jobs=-1)),\n    ('cat', CatBoostRegressor(iterations=2000, learning_rate=0.015, depth=7, random_state=42, verbose=0))\n]\n\nstack_model = StackingRegressor(\n    estimators=estimators,\n    final_estimator=Ridge(),\n    cv=5,\n    n_jobs=-1\n)\n\nstack_model.fit(X, y)\n\n\ntrained_xgb = stack_model.named_estimators_['xgb']\n\nimportances = pd.DataFrame({\n    'Variable': X.columns,\n    'Importance': trained_xgb.feature_importances_\n}).sort_values(by='Importance', ascending=False)\n\n\n\n","metadata":{"id":"iOlON-kKbhwb","outputId":"3ae84a58-0bc6-47af-aecb-245d453d45e2","trusted":true,"execution":{"iopub.status.busy":"2026-03-09T10:35:41.153996Z","iopub.execute_input":"2026-03-09T10:35:41.154443Z","iopub.status.idle":"2026-03-09T10:58:32.546486Z","shell.execute_reply.started":"2026-03-09T10:35:41.154416Z","shell.execute_reply":"2026-03-09T10:58:32.544084Z"}},"outputs":[],"execution_count":null},{"cell_type":"code","source":"final_predictions = stack_model.predict(X_test)\nfinal_predictions = np.clip(final_predictions, a_min=min_score, a_max=max_score)\n\nsubmission = pd.DataFrame({\n    'id': test_ids,\n    'exam_score': final_predictions\n})\n\nsubmission.to_csv('submission.csv', index=False)\ndisplay(submission.head())","metadata":{"trusted":true,"execution":{"iopub.status.busy":"2026-03-09T10:58:32.548227Z","iopub.execute_input":"2026-03-09