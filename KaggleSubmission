    "min_score = train['exam_score'].min()\n",
    "max_score = train['exam_score'].max()\n",
    "\n",
    "def super_pipeline(df):\n",
    "    df_clean = df.copy()\n",
    "\n",
    "    # 1. Mapping ordinal du sommeil\n",
    "    sleep_map = {'Poor': 0, 'poor': 0, 'Average': 1, 'average': 1, 'Good': 2, 'good': 2}\n",
    "    if 'sleep_quality' in df_clean.columns:\n",
    "        df_clean['sleep_quality'] = df_clean['sleep_quality'].map(sleep_map)\n",
    "\n",
    "    # 2. Feature Engineering restreint et qualitatif\n",
    "    df_clean['effort_index'] = df_clean['study_hours'] * df_clean['class_attendance']\n",
    "    df_clean['health_index'] = df_clean['sleep_hours'] * (df_clean['sleep_quality'] + 1)\n",
    "    df_clean['study_efficiency'] = df_clean['study_hours'] / (df_clean['sleep_quality'] + 1)\n",
    "\n",
    "    # 3. Suppression du bruit statistique\n",
    "    cols_to_drop = ['id', 'age', 'internet_access', 'exam_difficulty']\n",
    "    df_clean = df_clean.drop(columns=[c for c in cols_to_drop if c in df_clean.columns])\n",
    "\n",
    "    return df_clean"
   ]
